# Cricket-Insight-Pro Backend Environment Configuration

# MongoDB Connection URI (Replace with your Atlas or Local URI)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxx.mongodb.net/cricket_insight_pro?retryWrites=true&w=majority

# Database Name
DB_NAME=cricket_insight_pro

# Secret key for JWT signatures (Keep this secret in production!)
JWT_SECRET=cricket_insight_pro_super_secret_key_12345!

# Server Configuration
PORT=5000
HOST=0.0.0.0
DEBUG=True
